#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Generate a Tibbar test then run the testbench with the same seed.
#
# Usage:
#   ./scripts/rheon_run --test <testname> --seed <seed> [-v|--verbosity <level>]
#
# Creates runs/<testname>_seed<N>_<YYYYMMDD>_<HHMMSS>/ with test.S, test.elf; runs simulation
# with that ELF and RANDOM_SEED=<seed> for reproducibility.
# Equivalent to: rheon_gen --test <name> --seed <N> then rheon_sim --test <elf> --seed <N>.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "Usage: $0 --test <testname> --seed <seed> [-v|--verbosity <level>]" >&2
  echo "  --test       passed to Tibbar as --generator (e.g. simple)" >&2
  echo "  --seed       used for Tibbar and for testbench (RANDOM_SEED)" >&2
  echo "  -v, --verbosity  optional; logging level: debug, info, warning, error, critical (passed to rheon_sim)" >&2
  echo "  Run dir: runs/<testname>_seed<seed>_<YYYYMMDD>_<HHMMSS>/" >&2
  exit 1
}

TEST=""
SEED=""
VERBOSE_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --test) TEST="$2"; shift 2 ;;
    --seed) SEED="$2"; shift 2 ;;
    -v|--verbosity)
      if [[ -n "${2:-}" ]]; then
        VERBOSE_ARGS+=("$1" "$2"); shift 2
      else
        echo "Missing value for --verbosity" >&2
        usage
      fi
      ;;
    *) usage ;;
  esac
done
[[ -n "$TEST" ]] || usage
[[ -n "$SEED" ]] || usage

# Delegate to rheon_gen then rheon_sim
output="$("${SCRIPT_DIR}/rheon_gen" --test "$TEST" --seed "$SEED" 2>&1)"
echo "$output"
ELF="$(echo "$output" | tail -1)"
[[ -f "$ELF" ]] || { echo "rheon_gen did not produce ELF: $ELF" >&2; exit 1; }
echo "Rerun: ${SCRIPT_DIR}/rheon_run --test $TEST --seed $SEED" >&2
exec "${SCRIPT_DIR}/rheon_sim" --test "$ELF" --seed "$SEED" "${VERBOSE_ARGS[@]}"
