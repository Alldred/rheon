#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Run the testbench with an ELF (no generation).
#
# Usage:
#   ./scripts/rheon_sim --test <elf_path> [--seed <seed>] [-v|--verbosity <level>] [--waves]
#
# Runs the cocotb testbench with the given ELF. If --seed is given, uses RANDOM_SEED for reproducibility.
# Verbosity: -v or --verbosity sets logging level (debug, info, warning, error, critical). Case insensitive.
#   debug = include committed instruction ASM trace.

set -euo pipefail
RHEON_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Valid logging levels (case insensitive)
VALID_LEVELS="debug info warning error critical"

usage() {
  echo "Usage: $0 --test <elf_path> [--seed <seed>] [-v|--verbosity <level>] [--waves]" >&2
  echo "  --test       path to .elf file to load" >&2
  echo "  --seed       optional; if set, passed as RANDOM_SEED to cocotb" >&2
  echo "  -v, --verbosity  optional; logging level: debug, info, warning, error, critical (case insensitive)." >&2
  echo "  --waves      optional; enable simulator waveform dumping (passes WAVES=1 to make)." >&2
  exit 1
}

_test_level() {
  local want
  want=$(echo "$1" | tr '[:upper:]' '[:lower:]')
  for l in $VALID_LEVELS; do
    [[ "$l" == "$want" ]] && return 0
  done
  return 1
}

TEST=""
SEED=""
VERBOSITY=""
WAVES=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --test) TEST="$2"; shift 2 ;;
    --seed) SEED="$2"; shift 2 ;;
    -v|--verbosity)
      if [[ -n "${2:-}" ]] && _test_level "$2"; then
        VERBOSITY="$(echo "$2" | tr '[:upper:]' '[:lower:]')"
        shift 2
      else
        echo "Invalid or missing verbosity. Use one of: $VALID_LEVELS" >&2
        usage
      fi
      ;;
    --waves)
      WAVES=1
      shift
      ;;
    *) usage ;;
  esac
done
[[ -n "$TEST" ]] || usage
[[ -f "$TEST" ]] || { echo "ELF not found: $TEST" >&2; exit 1; }

# Run dir = directory containing the ELF; put results.xml there
RUN_DIR="$(cd "$(dirname "$TEST")" && pwd)"
export COCOTB_RESULTS_FILE="${RUN_DIR}/results.xml"
[[ -n "$VERBOSITY" ]] && export RHEON_VERBOSITY="$VERBOSITY"
WAVES_FILE="${RUN_DIR}/dump.vcd"

MAKE_ARGS=(ELF="$TEST")
[[ -n "$SEED" ]] && MAKE_ARGS+=(RANDOM_SEED="$SEED")
[[ -n "$VERBOSITY" ]] && MAKE_ARGS+=(RHEON_VERBOSITY="$VERBOSITY")
[[ "$WAVES" -eq 1 ]] && MAKE_ARGS+=(WAVES=1 WAVES_FILE="$WAVES_FILE")

if [[ -n "$SEED" ]]; then
  echo "Rerun: ${RHEON_ROOT}/scripts/rheon_sim --test $TEST --seed $SEED" >&2
else
  echo "Rerun: ${RHEON_ROOT}/scripts/rheon_sim --test $TEST" >&2
fi
[[ -n "$VERBOSITY" ]] && echo "Verbosity: $VERBOSITY" >&2
[[ "$WAVES" -eq 1 ]] && echo "Waves: enabled (WAVES=1), target: $WAVES_FILE" >&2
set +e
cd "$RHEON_ROOT" && make run "${MAKE_ARGS[@]}"
RC=$?
set -e
if [[ "$WAVES" -eq 1 ]]; then
  if [[ -f "$WAVES_FILE" ]]; then
    echo "Waves: $WAVES_FILE" >&2
  else
    echo "Waves requested but file not found yet: $WAVES_FILE" >&2
  fi
fi
exit $RC
