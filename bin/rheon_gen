#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
# Generate a Tibbar test only (no simulation).

from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT_DIR = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT_DIR / "scripts"))

from rheon_cli_common import ConfigError, generate_test  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Generate a Tibbar test only (no simulation).",
    )
    parser.add_argument("--test", required=True, help="Passed to Tibbar as --generator")
    parser.add_argument("--seed", required=True, help="Used for Tibbar")
    parser.add_argument(
        "--run-dir",
        type=Path,
        default=None,
        help="Optional explicit run directory (defaults to runs/<test>_seed<seed>_<timestamp>/)",
    )
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    try:
        elf = generate_test(
            test=args.test,
            seed=args.seed,
            run_dir=args.run_dir,
        )
    except (ConfigError, RuntimeError, OSError) as exc:
        print(str(exc), file=sys.stderr)
        return 1
    except Exception as exc:  # pragma: no cover - defensive fallback
        print(f"Unexpected error: {exc}", file=sys.stderr)
        return 1

    print(str(elf))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
