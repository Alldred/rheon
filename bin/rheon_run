#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
# Generate a Tibbar test then run the testbench with the same seed.

from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT_DIR = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT_DIR / "scripts"))

from rheon_cli_common import ConfigError, generate_test, run_simulation  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Generate a Tibbar test then run the testbench with the same seed.",
    )
    parser.add_argument("--test", required=True, help="Passed to Tibbar as --generator")
    parser.add_argument("--seed", required=True, help="Used for Tibbar and testbench")
    parser.add_argument(
        "-v",
        "--verbosity",
        default=None,
        help="Logging level: debug, info, warning, error, critical",
    )
    parser.add_argument(
        "--waves",
        action="store_true",
        help="Enable simulator waveform dumping",
    )
    parser.add_argument(
        "--run-dir",
        type=Path,
        default=None,
        help="Optional explicit run directory (defaults to runs/<test>_seed<seed>_<timestamp>/)",
    )
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    try:
        print(
            f"Generating test: rheon_gen --test {args.test} --seed {args.seed}",
            file=sys.stderr,
        )
        elf = generate_test(test=args.test, seed=args.seed, run_dir=args.run_dir)

        sim_desc = f"rheon_sim --test {elf} --seed {args.seed}"
        if args.verbosity:
            sim_desc += f" --verbosity {args.verbosity}"
        if args.waves:
            sim_desc += " --waves"
        print(f"Running simulation: {sim_desc}", file=sys.stderr)

        rerun = f"{Path(__file__).resolve()} --test {args.test} --seed {args.seed}"
        if args.verbosity:
            rerun += f" --verbosity {args.verbosity}"
        if args.waves:
            rerun += " --waves"
        if args.run_dir:
            rerun += f" --run-dir {args.run_dir}"
        print(f"Rerun: {rerun}", file=sys.stderr)

        return run_simulation(
            elf_path=elf,
            seed=args.seed,
            verbosity=args.verbosity,
            waves=bool(args.waves),
        )
    except ConfigError as exc:
        print(str(exc), file=sys.stderr)
        return 1
    except Exception as exc:  # pragma: no cover - defensive fallback
        print(f"Unexpected error: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
