#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
# Launch the local regression app.

from __future__ import annotations

import argparse
import os
import shutil
import sys
from dataclasses import dataclass
from importlib import import_module
from pathlib import Path

ROOT_DIR = Path(__file__).resolve().parents[1]
SCRIPT_PATH = Path(__file__).resolve()
SCRIPTS_DIR = ROOT_DIR / "scripts"
BOOTSTRAP_ENV = "RHEON_REGR_APP_BOOTSTRAPPED"

if str(SCRIPTS_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPTS_DIR))


@dataclass(frozen=True)
class RuntimeCommand:
    argv: list[str]
    cwd: Path | None = None


def _build_runtime_commands(argv: list[str]) -> list[RuntimeCommand]:
    if os.environ.get(BOOTSTRAP_ENV) == "1":
        return []

    commands: list[RuntimeCommand] = []
    repo_python = ROOT_DIR / ".venv" / "bin" / "python"
    current_python = Path(sys.executable).resolve()
    if repo_python.exists() and repo_python.resolve() != current_python:
        commands.append(RuntimeCommand([str(repo_python), str(SCRIPT_PATH), *argv]))

    uv = shutil.which("uv")
    if uv:
        commands.append(
            RuntimeCommand([uv, "run", "bin/rheon_regr_app", *argv], cwd=ROOT_DIR)
        )

    return commands


def _reexec_with_supported_runtime(argv: list[str]) -> None:
    env = os.environ.copy()
    env[BOOTSTRAP_ENV] = "1"
    last_error: OSError | None = None
    for command in _build_runtime_commands(argv):
        try:
            if command.cwd is not None:
                os.chdir(command.cwd)
            os.execvpe(command.argv[0], command.argv, env)
        except OSError as exc:  # pragma: no cover - defensive path
            last_error = exc
            continue

    if last_error is not None:
        raise last_error

    raise RuntimeError(
        "Could not import Rheon regression app dependencies. "
        "Run `uv sync` or use the project .venv."
    )


def _load_app_main(argv: list[str]):
    try:
        module = import_module("rheon_regr_app")
        return module.main
    except ModuleNotFoundError:
        _reexec_with_supported_runtime(argv)
        raise AssertionError("runtime re-exec returned unexpectedly")


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Start the rheon regression app")
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8765)
    parser.add_argument("--attach", default=None)
    return parser


def main_entry(argv: list[str] | None = None) -> int:
    cli_argv = list(sys.argv[1:] if argv is None else argv)
    args = _build_parser().parse_args(cli_argv)
    app_main = _load_app_main(cli_argv)
    return app_main(
        [f"--host={args.host}", f"--port={args.port}"]
        + ([f"--attach={args.attach}"] if args.attach else [])
    )


if __name__ == "__main__":
    raise SystemExit(main_entry())
