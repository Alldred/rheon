# Check for RHEON_ROOT already being set in the shell
if [[ "$RHEON_ROOT" != "" ]]; then
    echo "[\033[0;31mERROR\033[0m] Rheon shell is already activated!"
    exit 1
fi

# Work out where the repository is located
RHEON_ROOT=$(readlink -f ${0:a:h}/..)

# Check and update tibbar/lome before entering the shell
(
    cd "$RHEON_ROOT" || exit 1
    uv lock --upgrade-package tibbar --upgrade-package lome
    uv sync
) || {
    echo "[\033[0;31mERROR\033[0m] Failed to update tibbar/lome via uv" >&2
    exit 1
}

USER_HISTFILE=${HISTFILE:-$HOME/.zsh_history}

RHEON_ROOT=$RHEON_ROOT \
    USER_HISTFILE=$USER_HISTFILE \
    ZDOTDIR=$RHEON_ROOT/bin/zsh \
    /bin/zsh -i $@
